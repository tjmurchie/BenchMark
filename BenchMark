#!/usr/bin/env bash
# BenchMark — metagenomic classifier benchmarking tool
# Part of the Workbench toolkit (Hakai Institute / Tyler Murchie)
#
# Usage:
#   BenchMark go   --screen kr2 --tool Kraken2 --dataset calculus_sim
#   BenchMark mark "step_name"
#   BenchMark stop
#   BenchMark status
#   BenchMark merge run1.csv run2.csv -o combined.csv
#   BenchMark analyse combined.csv --output-dir ./plots

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export BENCHMARK_HOME="$SCRIPT_DIR"
export PYTHONPATH="${SCRIPT_DIR}:${PYTHONPATH:-}"

exec python3 "${SCRIPT_DIR}/benchmark/cli.py" "$@"
